{
  "annotations": {
    "list": []
  },
  "description": "SLO-Dashboard: Request Latency, Error Rate, Invoice Throughput, Service Availability",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Overview",
      "type": "dashboard",
      "url": "/d/erechnung-overview"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "⏱ Request Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "title": "Request Latency — p50 / p95 / p99",
      "type": "timeseries",
      "targets": [
        {
          "expr": "job:http_request_duration_seconds:p50_5m",
          "legendFormat": "p50"
        },
        {
          "expr": "job:http_request_duration_seconds:p95_5m",
          "legendFormat": "p95"
        },
        {
          "expr": "job:http_request_duration_seconds:p99_5m",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "title": "❌ Error Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "title": "HTTP 5xx Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "job:http_request_errors:rate5m",
          "legendFormat": "5xx Error Ratio"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "stat" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "title": "Availability (30d window)",
      "type": "stat",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "1 - job:http_request_errors:rate5m",
          "legendFormat": "Availability"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 6,
      "title": "📄 Invoice Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "title": "Invoices Created per Hour",
      "type": "timeseries",
      "targets": [
        {
          "expr": "job:invoices_created:rate1h",
          "legendFormat": "Invoices/h"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "title": "PDF Generation Failure Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(erechnung_pdf_generation_total{result=\"error\"}[15m]) / rate(erechnung_pdf_generation_total[15m])",
          "legendFormat": "PDF Error Rate"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["slo", "erechnung"],
  "templating": {
    "list": [
      {
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "eRechnung - SLO Dashboard",
  "uid": "erechnung-slo",
  "version": 1
}

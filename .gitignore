# See https://help.github.com/ignore-files/ for more about ignoring files.
lib/*
lib64/*
bin/*

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
.history/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
.env*
!.env.example
!.env.ci
venv/
ENV/
venv_test_installation/
venv.bak/
.venv*

# IDE-specific files
.vscode/
.idea/

# Compiled Python modules
*.pyc
*.pyo
*.pyd

# Python testing
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.*

# this application's specific files
/archive

# any log file
*.log
*log.txt
logs/
todo
scratchpad

# Pyenv
.python-version

.gpte_consent

# projects folder apart from default prompt

projects/*
!projects/example/prompt
!projects/example-improve
!projects/example-vision

# docs

docs/_build
docs/applications
docs/benchmark
docs/cli
docs/core
docs/intro
docs/tools
docs/arc42.bak
docs/req42.bak

# coding assistants
.aider*
.gpteng

# webapp specific
webapp/node_modules
webapp/package-lock.json

webapp/.next/

.langchain.db

# TODO files
/!todo*

# locally saved datasets
static
media

project_root/static
project_root/media
incoming_invoices

# Coverage reports (generated by pytest-cov)
htmlcov/
project_root/htmlcov/

# Security audit reports (generated by scripts/security_audit.sh)
security-reports/

# Obsolete/test files (replaced by new architecture)
*.obsolete
*.test
*.disabled

frontend/test-results/
test-artifacts/
!test-artifacts/update-tests/fixtures/

# Mustang-CLI JAR (downloaded by validate_invoice_mustang.sh)
scripts/Mustang-CLI-*.jar

# Backup files (created by scripts/backup.sh)
infra/backups/*/
!infra/backups/.gitkeep

# Let's Encrypt certificates (managed by certbot)
certbot/

# Docker Secrets (production secret files)
secrets/*
!secrets/.gitkeep
infra/postgres/certs/

# eRechnung Environment Configuration Template
# ==============================================
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Or use the generate-secrets.sh script to auto-generate secure values:
#   cd scripts && ./generate-secrets.sh
#
# ⚠️  NEVER commit .env with real secrets to Git!

# ─── Django Configuration ─────────────────────────────────────────────

# REQUIRED: Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# Set to False in production!
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,0.0.0.0

# Application version (set by CI/CD)
APP_VERSION=dev

# ─── Database Configuration ───────────────────────────────────────────

# REQUIRED: Use a strong password in production!
DB_NAME=erechnung
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_HOST=db
DB_PORT=5432

# PostgreSQL container variables (must match DB_ values)
POSTGRES_DB=erechnung
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Redis Configuration ─────────────────────────────────────────────

REDIS_HOST=redis
REDIS_PORT=6379
# Optional: Redis password (uncomment for production)
# REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ─── Celery Configuration ────────────────────────────────────────────

CELERY_BROKER_URL=redis://redis:6379/0

# ─── Docker Environment ──────────────────────────────────────────────

IS_DOCKER=true
BEHIND_GATEWAY=false
PYTHONPATH=/app/project_root

# ─── External Tools ──────────────────────────────────────────────────

GHOSTSCRIPT_PATH=/usr/bin/gs

# ─── E-Mail Delivery (Invoice Send) ──────────────────────────────────
#
# Hard kill-switch: when False the send_email API returns 503.
# Set to False on staging/CI environments to avoid accidental real sends.
INVOICE_EMAIL_ENABLED=True

# SMTP backend for production. For dev with Mailpit keep defaults below.
# Use 'django.core.mail.backends.console.EmailBackend' to log mails to stdout instead.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Dev default: Mailpit (docker-compose service). Production: smtp.ionos.de etc.
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=10

# Sender address shown to the recipient.
DEFAULT_FROM_EMAIL=no-reply@erechnung.local
SERVER_EMAIL=no-reply@erechnung.local

# Production example (IONOS):
# EMAIL_HOST=smtp.ionos.de
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=invoice@yourdomain.tld
# EMAIL_HOST_PASSWORD=CHANGE_ME_IONOS_MAIL_PASSWORD
# DEFAULT_FROM_EMAIL=invoice@yourdomain.tld

# ─── Testing (only for development) ──────────────────────────────────

TESTING_MODE=false

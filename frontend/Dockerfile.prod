# Production Dockerfile für Vue.js Frontend
# Use Node.js 22 LTS for build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Dependencies installieren
COPY package*.json ./
RUN npm ci

# App bauen
COPY . .
RUN npm run build

# Nginx für Production Serve
FROM nginx:alpine

# Vite Build-Artefakte kopieren
COPY --from=builder /app/dist /usr/share/nginx/html

# Nginx-Konfiguration für SPA
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
